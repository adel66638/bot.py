<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>نيورا — مساعد الذكاء الاصطناعي</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #050810;
    --surface: #0d1117;
    --surface2: #161b27;
    --border: #1e2840;
    --accent: #00d4ff;
    --accent2: #7c3aed;
    --accent3: #10b981;
    --text: #e2e8f0;
    --text-dim: #64748b;
    --glow: 0 0 20px rgba(0,212,255,0.3);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Cairo', sans-serif;
    background: var(--bg);
    color: var(--text);
    height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
  }

  /* Animated background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: 
      radial-gradient(ellipse 80% 50% at 20% 20%, rgba(124,58,237,0.08) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 80% 80%, rgba(0,212,255,0.06) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  /* Grid pattern */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background-image: 
      linear-gradient(rgba(0,212,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,212,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  /* Header */
  header {
    position: relative;
    z-index: 10;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
    background: rgba(13,17,23,0.9);
    backdrop-filter: blur(20px);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--accent2), var(--accent));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    box-shadow: 0 0 20px rgba(124,58,237,0.4);
    animation: pulse-logo 3s ease-in-out infinite;
  }

  @keyframes pulse-logo {
    0%, 100% { box-shadow: 0 0 20px rgba(124,58,237,0.4); }
    50% { box-shadow: 0 0 35px rgba(124,58,237,0.7), 0 0 60px rgba(0,212,255,0.2); }
  }

  .logo-text {
    font-size: 22px;
    font-weight: 900;
    background: linear-gradient(135deg, #fff 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: 1px;
  }

  .logo-sub {
    font-size: 10px;
    color: var(--text-dim);
    font-family: 'Space Mono', monospace;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  /* Mode pills */
  .modes {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .mode-btn {
    padding: 6px 14px;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    font-family: 'Cairo', sans-serif;
    font-size: 12px;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .mode-btn:hover, .mode-btn.active {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(0,212,255,0.08);
    box-shadow: 0 0 12px rgba(0,212,255,0.15);
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent3);
    animation: blink 2s infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* Main layout */
  .main {
    flex: 1;
    display: flex;
    overflow: hidden;
    position: relative;
    z-index: 1;
  }

  /* Chat area */
  .chat-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  #messages {
    flex: 1;
    overflow-y: auto;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    scroll-behavior: smooth;
  }

  #messages::-webkit-scrollbar { width: 4px; }
  #messages::-webkit-scrollbar-track { background: transparent; }
  #messages::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* Welcome screen */
  .welcome {
    text-align: center;
    margin: auto;
    padding: 40px 20px;
    max-width: 600px;
  }

  .welcome-icon {
    font-size: 56px;
    margin-bottom: 20px;
    animation: float 4s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .welcome h2 {
    font-size: 32px;
    font-weight: 900;
    background: linear-gradient(135deg, #fff, var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 12px;
  }

  .welcome p {
    color: var(--text-dim);
    font-size: 15px;
    line-height: 1.8;
    margin-bottom: 32px;
  }

  .suggestions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    text-align: right;
  }

  .suggestion {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 16px;
    cursor: pointer;
    transition: all 0.25s;
    text-align: right;
  }

  .suggestion:hover {
    border-color: var(--accent);
    background: rgba(0,212,255,0.05);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,212,255,0.1);
  }

  .suggestion-icon { font-size: 20px; margin-bottom: 6px; }
  .suggestion-title { font-size: 13px; font-weight: 700; color: var(--text); }
  .suggestion-desc { font-size: 11px; color: var(--text-dim); margin-top: 4px; line-height: 1.5; }

  /* Messages */
  .msg {
    display: flex;
    gap: 12px;
    animation: msg-in 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes msg-in {
    from { opacity: 0; transform: translateY(16px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .msg.user { flex-direction: row-reverse; }

  .avatar {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .avatar.ai {
    background: linear-gradient(135deg, var(--accent2), var(--accent));
    box-shadow: 0 0 14px rgba(124,58,237,0.4);
  }

  .avatar.user-av {
    background: linear-gradient(135deg, #1e293b, #334155);
    border: 1px solid var(--border);
  }

  .bubble {
    max-width: 75%;
    padding: 14px 18px;
    border-radius: 16px;
    font-size: 14.5px;
    line-height: 1.75;
    position: relative;
  }

  .msg.ai .bubble {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-top-right-radius: 4px;
  }

  .msg.user .bubble {
    background: linear-gradient(135deg, rgba(124,58,237,0.3), rgba(0,212,255,0.15));
    border: 1px solid rgba(0,212,255,0.2);
    border-top-left-radius: 4px;
  }

  .bubble p { margin-bottom: 8px; }
  .bubble p:last-child { margin-bottom: 0; }
  .bubble strong { color: var(--accent); }
  .bubble code {
    background: rgba(0,212,255,0.1);
    border: 1px solid rgba(0,212,255,0.2);
    padding: 1px 6px;
    border-radius: 4px;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    color: var(--accent);
  }

  .mode-tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 10px;
    color: var(--accent);
    background: rgba(0,212,255,0.1);
    border: 1px solid rgba(0,212,255,0.2);
    padding: 2px 8px;
    border-radius: 10px;
    margin-bottom: 8px;
    font-family: 'Space Mono', monospace;
  }

  /* Typing indicator */
  .typing {
    display: flex;
    gap: 5px;
    padding: 6px 0;
  }

  .typing span {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    animation: typing 1.4s infinite;
  }

  .typing span:nth-child(2) { animation-delay: 0.2s; }
  .typing span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes typing {
    0%, 80%, 100% { transform: scale(0.7); opacity: 0.4; }
    40% { transform: scale(1); opacity: 1; }
  }

  /* Input area */
  .input-area {
    padding: 16px 24px 20px;
    background: rgba(13,17,23,0.95);
    backdrop-filter: blur(20px);
    border-top: 1px solid var(--border);
  }

  .input-wrapper {
    display: flex;
    align-items: flex-end;
    gap: 12px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 12px 16px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .input-wrapper:focus-within {
    border-color: rgba(0,212,255,0.4);
    box-shadow: 0 0 0 3px rgba(0,212,255,0.08), var(--glow);
  }

  #userInput {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font-family: 'Cairo', sans-serif;
    font-size: 14.5px;
    resize: none;
    max-height: 140px;
    min-height: 24px;
    line-height: 1.6;
    direction: rtl;
  }

  #userInput::placeholder { color: var(--text-dim); }

  .send-btn {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--accent2), var(--accent));
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
    transition: all 0.2s;
    box-shadow: 0 4px 14px rgba(0,212,255,0.25);
  }

  .send-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 20px rgba(0,212,255,0.4);
  }

  .send-btn:active { transform: scale(0.96); }
  .send-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  .input-hint {
    text-align: center;
    font-size: 11px;
    color: var(--text-dim);
    margin-top: 10px;
    font-family: 'Space Mono', monospace;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  /* Scrollbar */
  * { scrollbar-width: thin; scrollbar-color: var(--border) transparent; }
</style>
</head>
<body>

<header>
  <div class="logo">
    <div class="logo-icon">🧠</div>
    <div>
      <div class="logo-text">نيورا</div>
      <div class="logo-sub">AI · POWERED BY CLAUDE</div>
    </div>
  </div>

  <div class="modes">
    <button class="mode-btn active" data-mode="general" onclick="setMode(this)">🌐 عام</button>
    <button class="mode-btn" data-mode="analyze" onclick="setMode(this)">🔬 تحليل</button>
    <button class="mode-btn" data-mode="research" onclick="setMode(this)">📚 بحث</button>
    <button class="mode-btn" data-mode="design" onclick="setMode(this)">🎨 تصميم</button>
    <button class="mode-btn" data-mode="discuss" onclick="setMode(this)">💬 نقاش</button>
    <div style="display:flex;align-items:center;gap:6px;margin-right:8px;padding-right:8px;border-right:1px solid var(--border)">
      <div class="status-dot"></div>
      <span style="font-size:11px;color:var(--text-dim)">متصل</span>
    </div>
  </div>
</header>

<div class="main">
  <div class="chat-area">
    <div id="messages">
      <div class="welcome" id="welcome">
        <div class="welcome-icon">⚡</div>
        <h2>مرحباً، كيف أساعدك؟</h2>
        <p>مساعد ذكاء اصطناعي متكامل — يحلل، يبحث، يناقش، ويصمم.<br>اختر الوضع المناسب من الأعلى أو ابدأ مباشرة.</p>
        <div class="suggestions">
          <div class="suggestion" onclick="useSuggestion(this)">
            <div class="suggestion-icon">🔬</div>
            <div class="suggestion-title">تحليل نص أو بيانات</div>
            <div class="suggestion-desc">حلل هذا المحتوى وأعطني أبرز النقاط والاستنتاجات</div>
          </div>
          <div class="suggestion" onclick="useSuggestion(this)">
            <div class="suggestion-icon">📚</div>
            <div class="suggestion-title">البحث في موضوع</div>
            <div class="suggestion-desc">ابحث لي عن أحدث المعلومات حول موضوع معين</div>
          </div>
          <div class="suggestion" onclick="useSuggestion(this)">
            <div class="suggestion-icon">🎨</div>
            <div class="suggestion-title">تصميم أو كود</div>
            <div class="suggestion-desc">صمم لي واجهة أو اكتب كوداً بلغة معينة</div>
          </div>
          <div class="suggestion" onclick="useSuggestion(this)">
            <div class="suggestion-icon">💬</div>
            <div class="suggestion-title">نقاش فكري</div>
            <div class="suggestion-desc">ناقشني في موضوع وأعطني آراء من زوايا متعددة</div>
          </div>
        </div>
      </div>
    </div>

    <div class="input-area">
      <div class="input-wrapper">
        <textarea
          id="userInput"
          placeholder="اكتب رسالتك هنا... (Enter للإرسال، Shift+Enter لسطر جديد)"
          rows="1"
          onkeydown="handleKey(event)"
          oninput="autoResize(this)"
        ></textarea>
        <button class="send-btn" onclick="sendMessage()" id="sendBtn" title="إرسال">➤</button>
      </div>
      <div class="input-hint">
        <span>⌨️ Enter للإرسال</span>
        <span>·</span>
        <span>Shift+Enter لسطر جديد</span>
        <span>·</span>
        <span id="modeLabel" style="color:var(--accent)">وضع: عام</span>
      </div>
    </div>
  </div>
</div>

<script>
let currentMode = 'general';
let isLoading = false;

const modeConfig = {
  general: { label: 'عام', icon: '🌐', prompt: 'أنت مساعد ذكاء اصطناعي ذكي ومفيد. أجب بالعربية بشكل واضح ومنظم.' },
  analyze: { label: 'تحليل', icon: '🔬', prompt: 'أنت محلل خبير. قم بتحليل المحتوى المقدم بعمق: استخرج النقاط الرئيسية، الأنماط، الاستنتاجات، ونقاط القوة والضعف. كن منهجياً ودقيقاً. أجب بالعربية.' },
  research: { label: 'بحث', icon: '📚', prompt: 'أنت باحث أكاديمي متخصص. قدم معلومات شاملة ودقيقة مع ذكر الجوانب المختلفة للموضوع. نظّم إجابتك بشكل علمي واضح. أجب بالعربية.' },
  design: { label: 'تصميم', icon: '🎨', prompt: 'أنت مصمم ومطور خبير. عند طلب تصميم أو كود، قدم حلاً احترافياً ومتكاملاً مع شرح الخيارات والبدائل. أجب بالعربية.' },
  discuss: { label: 'نقاش', icon: '💬', prompt: 'أنت محاور فكري ذو خبرة. ناقش الموضوع من زوايا متعددة، قدم حججاً وأدلة، وحفّز التفكير النقدي. كن منفتحاً ومحايداً. أجب بالعربية.' }
};

function setMode(btn) {
  document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  currentMode = btn.dataset.mode;
  const cfg = modeConfig[currentMode];
  document.getElementById('modeLabel').textContent = `وضع: ${cfg.label}`;
  document.getElementById('userInput').placeholder = `[${cfg.icon} ${cfg.label}] اكتب رسالتك...`;
}

function useSuggestion(el) {
  const title = el.querySelector('.suggestion-title').textContent;
  document.getElementById('userInput').value = title;
  autoResize(document.getElementById('userInput'));
  document.getElementById('userInput').focus();
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 140) + 'px';
}

function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
}

function hideWelcome() {
  const w = document.getElementById('welcome');
  if (w) w.remove();
}

function addMessage(role, content) {
  hideWelcome();
  const container = document.getElementById('messages');
  const cfg = modeConfig[currentMode];

  const div = document.createElement('div');
  div.className = `msg ${role}`;

  const avatar = document.createElement('div');
  avatar.className = `avatar ${role === 'ai' ? 'ai' : 'user-av'}`;
  avatar.textContent = role === 'ai' ? '🧠' : '👤';

  const bubble = document.createElement('div');
  bubble.className = 'bubble';

  if (role === 'ai') {
    const tag = document.createElement('div');
    tag.className = 'mode-tag';
    tag.innerHTML = `${cfg.icon} ${cfg.label}`;
    bubble.appendChild(tag);
  }

  const text = document.createElement('div');
  text.innerHTML = formatText(content);
  bubble.appendChild(text);

  div.appendChild(avatar);
  div.appendChild(bubble);
  container.appendChild(div);
  container.scrollTop = container.scrollHeight;
  return { bubble, text };
}

function formatText(t) {
  return t
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/\n\n/g, '</p><p>')
    .replace(/\n/g, '<br>')
    .replace(/^/, '<p>').replace(/$/, '</p>');
}

function showTyping() {
  hideWelcome();
  const container = document.getElementById('messages');
  const div = document.createElement('div');
  div.className = 'msg ai';
  div.id = 'typing-indicator';

  const avatar = document.createElement('div');
  avatar.className = 'avatar ai';
  avatar.textContent = '🧠';

  const bubble = document.createElement('div');
  bubble.className = 'bubble';
  bubble.innerHTML = '<div class="typing"><span></span><span></span><span></span></div>';

  div.appendChild(avatar);
  div.appendChild(bubble);
  container.appendChild(div);
  container.scrollTop = container.scrollHeight;
}

function removeTyping() {
  const t = document.getElementById('typing-indicator');
  if (t) t.remove();
}

async function sendMessage() {
  if (isLoading) return;
  const input = document.getElementById('userInput');
  const text = input.value.trim();
  if (!text) return;

  isLoading = true;
  document.getElementById('sendBtn').disabled = true;

  addMessage('user', text);
  input.value = '';
  input.style.height = 'auto';

  showTyping();

  try {
    const cfg = modeConfig[currentMode];
    const response = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-20250514",
        max_tokens: 1000,
        system: cfg.prompt,
        messages: [{ role: "user", content: text }]
      })
    });

    removeTyping();

    if (!response.ok) throw new Error(`HTTP ${response.status}`);
    const data = await response.json();
    const reply = data.content?.[0]?.text || 'حدث خطأ في الاستجابة.';
    addMessage('ai', reply);

  } catch (err) {
    removeTyping();
    addMessage('ai', `⚠️ **خطأ في الاتصال**\n\n${err.message}\n\nتأكد من أن النموذج يعمل في بيئة تدعم Anthropic API.`);
  }

  isLoading = false;
  document.getElementById('sendBtn').disabled = false;
  input.focus();
}
</script>
</body>
</html>
