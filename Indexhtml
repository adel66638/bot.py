<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SAKR5 V5 — الذكاء الاصطناعي</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg:       #010912;
  --bg2:      #071220;
  --bg3:      #0c1e35;
  --blue:     #1a6dff;
  --blue2:    #3d8bff;
  --accent:   #00e5ff;
  --green:    #00ff99;
  --white:    #f0f8ff;
  --dim:      #6a9cc8;
  --border:   rgba(26,109,255,0.18);
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html, body { height:100%; overflow:hidden; }

body {
  font-family:'Tajawal',sans-serif;
  background:var(--bg);
  color:var(--white);
  display:flex;
  flex-direction:column;
}

/* ─── BACKGROUND ─── */
#bg-grid {
  position:fixed; inset:0; pointer-events:none; z-index:0;
  background-image:
    linear-gradient(rgba(26,109,255,.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(26,109,255,.025) 1px, transparent 1px);
  background-size:50px 50px;
}
.glow {
  position:fixed; border-radius:50%; pointer-events:none; z-index:0;
}
.glow-1 {
  width:550px; height:550px;
  background:radial-gradient(circle, rgba(26,109,255,.1) 0%, transparent 70%);
  top:-180px; right:-120px;
  animation:drift 12s ease-in-out infinite alternate;
}
.glow-2 {
  width:380px; height:380px;
  background:radial-gradient(circle, rgba(0,229,255,.07) 0%, transparent 70%);
  bottom:-100px; left:-60px;
  animation:drift 16s ease-in-out infinite alternate-reverse;
}
@keyframes drift {
  from { transform:translate(0,0); }
  to   { transform:translate(40px,30px); }
}

/* ─── LAYOUT ─── */
.app { display:flex; height:100vh; position:relative; z-index:5; }

/* ─── SIDEBAR ─── */
.sidebar {
  width:250px; flex-shrink:0;
  background:rgba(7,18,32,.96);
  border-left:1px solid var(--border);
  display:flex; flex-direction:column;
  backdrop-filter:blur(20px);
}

.sb-header {
  padding:18px 16px 14px;
  border-bottom:1px solid var(--border);
}
.sb-logo-row { display:flex; align-items:center; gap:10px; margin-bottom:4px; }
.sb-icon {
  width:38px; height:38px; border-radius:10px;
  background:linear-gradient(135deg,#0d2a5e,var(--blue));
  display:flex; align-items:center; justify-content:center;
  font-family:'Space Mono',monospace; font-size:11px; font-weight:700;
  color:var(--accent); box-shadow:0 0 16px rgba(0,229,255,.28);
  flex-shrink:0;
}
.sb-name {
  font-family:'Space Mono',monospace;
  font-size:19px; font-weight:700; letter-spacing:4px;
  background:linear-gradient(135deg,#fff,var(--accent));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  background-clip:text;
}
.sb-ver {
  font-family:'Space Mono',monospace;
  font-size:9px; color:var(--dim); letter-spacing:2px; margin-right:48px;
}

.new-btn {
  margin:14px 14px 0;
  padding:10px;
  background:linear-gradient(135deg,var(--blue),#0a44cc);
  border:none; border-radius:10px;
  color:#fff; font-family:'Tajawal',sans-serif;
  font-size:14px; font-weight:700; letter-spacing:1px;
  cursor:pointer;
  box-shadow:0 4px 14px rgba(26,109,255,.3);
  transition:all .2s;
}
.new-btn:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(26,109,255,.45); }

.sb-section { padding:14px 14px 0; }
.sb-label {
  font-size:10px; color:var(--dim);
  font-family:'Space Mono',monospace;
  letter-spacing:2px; text-transform:uppercase;
  padding:0 4px; margin-bottom:8px;
}
.chat-item {
  padding:10px 12px; border-radius:9px;
  font-size:13px; color:var(--dim);
  cursor:pointer; transition:all .2s;
  display:flex; align-items:center; gap:8px;
  white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
  border-right:2px solid transparent;
}
.chat-item:hover { background:rgba(26,109,255,.1); color:var(--white); }
.chat-item.active { background:rgba(26,109,255,.15); color:var(--white); border-right-color:var(--blue); }

.sb-bottom {
  margin-top:auto;
  padding:14px;
  border-top:1px solid var(--border);
}
.key-btn {
  width:100%; padding:10px;
  background:rgba(255,255,255,.04);
  border:1px solid var(--border);
  border-radius:10px;
  color:var(--dim); font-family:'Tajawal',sans-serif;
  font-size:13px; cursor:pointer;
  display:flex; align-items:center; justify-content:center; gap:8px;
  transition:all .2s;
}
.key-btn:hover { border-color:var(--accent); color:var(--accent); }
.k-dot { width:7px; height:7px; border-radius:50%; background:#ff4466; transition:all .3s; }
.k-dot.on { background:var(--green); box-shadow:0 0 7px var(--green); }

/* ─── MAIN ─── */
.main { flex:1; display:flex; flex-direction:column; overflow:hidden; min-width:0; }

/* ─── TOPBAR ─── */
.topbar {
  padding:12px 24px;
  border-bottom:1px solid var(--border);
  background:rgba(1,9,18,.85);
  backdrop-filter:blur(20px);
  display:flex; align-items:center; justify-content:space-between;
  flex-shrink:0;
}
.model-pill {
  display:flex; align-items:center; gap:8px;
  padding:6px 14px;
  background:rgba(26,109,255,.08);
  border:1px solid var(--border); border-radius:20px;
}
.m-dot { width:6px; height:6px; border-radius:50%; background:var(--green); box-shadow:0 0 6px var(--green); animation:blink 2s infinite; }
@keyframes blink { 0%,100%{opacity:1;} 50%{opacity:.3;} }
.model-name { font-size:12px; font-family:'Space Mono',monospace; color:var(--dim); }

.top-actions { display:flex; gap:8px; }
.top-btn {
  padding:6px 14px;
  background:transparent;
  border:1px solid var(--border); border-radius:8px;
  color:var(--dim); font-size:12px;
  font-family:'Space Mono',monospace;
  cursor:pointer; transition:all .2s;
}
.top-btn:hover { border-color:var(--blue2); color:var(--white); }

/* ─── TABS ─── */
.tabs {
  display:flex; flex-shrink:0;
  border-bottom:1px solid rgba(26,109,255,.12);
  background:rgba(1,9,18,.7);
}
.tab {
  padding:10px 22px;
  background:transparent; border:none;
  border-bottom:2px solid transparent;
  color:var(--dim); font-family:'Tajawal',sans-serif;
  font-size:13px; cursor:pointer; transition:all .2s;
}
.tab.active { border-bottom-color:var(--blue); color:var(--white); }
.tab:hover:not(.active) { color:var(--white); }

/* ─── CHAT ─── */
#chat {
  flex:1; overflow-y:auto;
  padding:24px 28px;
  display:flex; flex-direction:column; gap:20px;
  scroll-behavior:smooth;
}
#chat::-webkit-scrollbar { width:3px; }
#chat::-webkit-scrollbar-thumb { background:rgba(26,109,255,.2); border-radius:2px; }

/* Welcome */
.welcome {
  text-align:center; padding:52px 20px;
  animation:fadeUp .7s ease;
}
.eagle {
  font-size:70px; display:block; margin-bottom:20px;
  animation:float 3s ease-in-out infinite;
  filter:drop-shadow(0 0 24px rgba(0,229,255,.5));
}
@keyframes float { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-12px);} }
.w-title {
  font-family:'Space Mono',monospace;
  font-size:34px; letter-spacing:6px;
  background:linear-gradient(135deg,#fff 0%,var(--accent) 55%,var(--green) 100%);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  background-clip:text; margin-bottom:5px;
}
.w-ver { font-family:'Space Mono',monospace; font-size:10px; color:var(--dim); letter-spacing:3px; margin-bottom:14px; }
.w-sub { color:var(--dim); font-size:14px; line-height:1.75; margin-bottom:28px; }

.sugs { display:flex; flex-wrap:wrap; gap:9px; justify-content:center; }
.sug {
  padding:9px 17px;
  background:rgba(26,109,255,.07);
  border:1px solid var(--border); border-radius:22px;
  color:var(--dim); font-size:13px; cursor:pointer;
  transition:all .25s; font-family:'Tajawal',sans-serif;
}
.sug:hover {
  background:rgba(26,109,255,.18);
  border-color:var(--blue2); color:var(--white);
  transform:translateY(-2px);
}

/* Messages */
.msg { display:flex; gap:10px; animation:fadeUp .35s ease; }
@keyframes fadeUp { from{opacity:0;transform:translateY(14px);} to{opacity:1;transform:translateY(0);} }

.msg.user { flex-direction:row-reverse; max-width:75%; margin-left:auto; }
.msg.ai   { max-width:82%; margin-right:auto; }

.av {
  width:35px; height:35px; border-radius:9px;
  display:flex; align-items:center; justify-content:center;
  flex-shrink:0; align-self:flex-end;
}
.msg.ai  .av { background:linear-gradient(135deg,#091e3a,var(--blue)); box-shadow:0 0 13px rgba(26,109,255,.4); font-family:'Space Mono',monospace; font-size:9px; font-weight:700; color:var(--accent); }
.msg.user .av { background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.1); font-size:16px; }

.bbl { padding:13px 17px; border-radius:14px; font-size:14px; line-height:1.8; word-break:break-word; white-space:pre-wrap; }
.msg.ai   .bbl { background:rgba(7,18,32,.95); border:1px solid var(--border); border-bottom-right-radius:3px; color:#cce4ff; }
.msg.user .bbl { background:linear-gradient(135deg,var(--blue),#0a44cc); border-bottom-left-radius:3px; color:#fff; box-shadow:0 4px 16px rgba(26,109,255,.28); }

/* Typing dots */
.dots { display:flex; gap:5px; align-items:center; padding:4px 0; }
.dots span { width:7px; height:7px; border-radius:50%; background:var(--accent); display:block; }
.dots span:nth-child(1) { animation:bounce 1.2s infinite; }
.dots span:nth-child(2) { animation:bounce 1.2s .2s infinite; }
.dots span:nth-child(3) { animation:bounce 1.2s .4s infinite; }
@keyframes bounce { 0%,60%,100%{transform:translateY(0);opacity:.3;} 30%{transform:translateY(-8px);opacity:1;} }

/* ─── INPUT ─── */
.input-zone {
  flex-shrink:0;
  padding:14px 28px 18px;
  background:rgba(1,9,18,.92);
  backdrop-filter:blur(22px);
  border-top:1px solid var(--border);
}
.no-key-bar {
  text-align:center; margin-bottom:10px;
  padding:9px 14px;
  background:rgba(255,100,50,.07);
  border:1px solid rgba(255,100,50,.22);
  border-radius:10px; font-size:12px; color:#ff9977; cursor:pointer;
}
.no-key-bar u { cursor:pointer; }
.input-wrap {
  display:flex; align-items:flex-end; gap:10px;
  background:rgba(255,255,255,.03);
  border:1px solid var(--border); border-radius:14px;
  padding:10px 14px; transition:border-color .25s, box-shadow .25s;
}
.input-wrap:focus-within { border-color:rgba(26,109,255,.5); box-shadow:0 0 20px rgba(26,109,255,.1); }
#msgInput {
  flex:1; background:transparent; border:none; outline:none;
  color:var(--white); font-family:'Tajawal',sans-serif;
  font-size:15px; resize:none; line-height:1.6;
  max-height:120px; min-height:26px;
}
#msgInput::placeholder { color:rgba(106,156,200,.45); }
#sendBtn {
  width:40px; height:40px; border-radius:10px;
  background:linear-gradient(135deg,var(--blue),#0a44cc);
  border:none; cursor:pointer; flex-shrink:0;
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 0 16px rgba(26,109,255,.32); transition:all .2s;
}
#sendBtn:hover { transform:scale(1.08); box-shadow:0 0 24px rgba(26,109,255,.55); }
#sendBtn:disabled { opacity:.35; cursor:default; transform:none; box-shadow:none; }
#sendBtn svg { width:17px; height:17px; fill:#fff; }
.hint { text-align:center; margin-top:7px; font-size:10px; color:rgba(106,156,200,.3); font-family:'Space Mono',monospace; }

/* ─── ABOUT PAGE ─── */
#aboutPage {
  flex:1; overflow-y:auto; padding:28px; display:none; flex-direction:column; gap:14px;
}
#aboutPage::-webkit-scrollbar { width:3px; }
#aboutPage::-webkit-scrollbar-thumb { background:rgba(26,109,255,.2); border-radius:2px; }
.about-card {
  background:rgba(7,18,32,.9);
  border:1px solid var(--border); border-radius:14px; padding:22px;
}
.about-card h3 { font-family:'Space Mono',monospace; font-size:12px; letter-spacing:2px; color:var(--accent); margin-bottom:12px; }
.about-card p { font-size:14px; color:#8ab0d8; line-height:1.8; }
.feat-grid { display:grid; grid-template-columns:1fr 1fr; gap:9px; margin-top:10px; }
.feat { background:rgba(26,109,255,.07); border:1px solid rgba(26,109,255,.14); border-radius:9px; padding:10px 13px; font-size:13px; color:#cce4ff; }
.ver-list { display:flex; flex-direction:column; gap:8px; margin-top:4px; }
.ver-row { display:flex; align-items:center; gap:10px; font-size:13px; color:#8ab0d8; }
.ver-tag { padding:3px 10px; border-radius:20px; background:rgba(26,109,255,.12); font-family:'Space Mono',monospace; font-size:10px; color:var(--blue2); }
.ver-tag.latest { background:rgba(0,229,255,.12); color:var(--accent); }

/* ─── MODAL ─── */
#modalOverlay {
  display:none; position:fixed; inset:0;
  background:rgba(1,9,18,.88); backdrop-filter:blur(12px);
  z-index:200; align-items:center; justify-content:center;
}
#modalOverlay.show { display:flex; }
.modal {
  background:var(--bg3); border:1px solid var(--border); border-radius:18px;
  padding:28px; width:90%; max-width:430px;
  box-shadow:0 24px 70px rgba(0,0,0,.6);
  animation:popIn .3s ease;
}
@keyframes popIn { from{opacity:0;transform:scale(.94) translateY(12px);} to{opacity:1;transform:scale(1) translateY(0);} }
.m-title { font-family:'Space Mono',monospace; font-size:15px; letter-spacing:2px; color:var(--accent); margin-bottom:8px; }
.m-desc  { font-size:13px; color:var(--dim); line-height:1.7; margin-bottom:18px; }
.m-desc strong { color:var(--accent); }
#keyInput {
  width:100%; padding:12px 14px;
  background:rgba(255,255,255,.04);
  border:1px solid var(--border); border-radius:10px;
  color:var(--white); font-size:13px; font-family:'Space Mono',monospace;
  outline:none; margin-bottom:14px; direction:ltr; transition:border-color .2s;
}
#keyInput:focus { border-color:var(--blue); }
.m-btns { display:flex; gap:10px; }
.m-save {
  flex:1; padding:12px;
  background:linear-gradient(135deg,var(--blue),#0a44cc);
  border:none; border-radius:10px;
  color:#fff; font-family:'Tajawal',sans-serif; font-size:14px; font-weight:700; cursor:pointer;
  transition:opacity .2s;
}
.m-save:hover { opacity:.85; }
.m-cancel {
  padding:12px 18px; background:transparent;
  border:1px solid var(--border); border-radius:10px;
  color:var(--dim); font-family:'Tajawal',sans-serif; font-size:14px; cursor:pointer;
  transition:all .2s;
}
.m-cancel:hover { border-color:var(--dim); color:var(--white); }
</style>
</head>
<body>

<div id="bg-grid"></div>
<div class="glow glow-1"></div>
<div class="glow glow-2"></div>

<!-- MODAL -->
<div id="modalOverlay">
  <div class="modal">
    <div class="m-title">🔑 SAKR5 V5 · API KEY</div>
    <div class="m-desc">أدخل مفتاح Claude API لتفعيل SAKR5.<br>احصل عليه من <strong>console.anthropic.com</strong></div>
    <input type="password" id="keyInput" placeholder="sk-ant-api03-..." />
    <div class="m-btns">
      <button class="m-save" onclick="saveKey()">تفعيل SAKR5 🦅</button>
      <button class="m-cancel" onclick="closeModal()">إلغاء</button>
    </div>
  </div>
</div>

<!-- APP -->
<div class="app">

  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="sb-header">
      <div class="sb-logo-row">
        <div class="sb-icon">S5</div>
        <div>
          <div class="sb-name">SAKR5</div>
        </div>
      </div>
      <div class="sb-ver">VERSION 5.0 · AI ASSISTANT</div>
    </div>

    <button class="new-btn" onclick="newChat()">+ محادثة جديدة</button>

    <div class="sb-section" style="margin-top:14px">
      <div class="sb-label">المحادثات</div>
      <div class="chat-item active" id="currentItem">💬 محادثة جديدة</div>
    </div>

    <div class="sb-bottom">
      <button class="key-btn" onclick="openModal()">
        <div class="k-dot" id="kDot"></div>
        <span id="kTxt">إضافة API Key</span>
      </button>
    </div>
  </div>

  <!-- MAIN -->
  <div class="main">

    <!-- TOPBAR -->
    <div class="topbar">
      <div class="model-pill">
        <div class="m-dot"></div>
        <div class="model-name">claude-sonnet-4 · SAKR5 v5.0</div>
      </div>
      <div class="top-actions">
        <button class="top-btn" onclick="newChat()">🗑 مسح</button>
        <button class="top-btn" onclick="openModal()">🔑 API</button>
      </div>
    </div>

    <!-- TABS -->
    <div class="tabs">
      <button class="tab active" id="tabChat" onclick="switchTab('chat')">💬 المحادثة</button>
      <button class="tab" id="tabAbout" onclick="switchTab('about')">🦅 عن SAKR5</button>
    </div>

    <!-- CHAT AREA -->
    <div id="chat">
      <div class="welcome" id="welcomeEl">
        <span class="eagle">🦅</span>
        <div class="w-title">SAKR5</div>
        <div class="w-ver">VERSION 5.0 · POWERED BY CLAUDE AI</div>
        <div class="w-sub">مساعدك الذكي المتقدم — سريع، دقيق، واحترافي</div>
        <div class="sugs">
          <button class="sug" onclick="useSug(this)">ما هو الذكاء الاصطناعي؟</button>
          <button class="sug" onclick="useSug(this)">ساعدني في كتابة كود Python</button>
          <button class="sug" onclick="useSug(this)">اشرح مفهوماً معقداً</button>
          <button class="sug" onclick="useSug(this)">أنشئ خطة عمل احترافية</button>
          <button class="sug" onclick="useSug(this)">ترجم نصاً إلى الإنجليزية</button>
          <button class="sug" onclick="useSug(this)">لخص موضوعاً علمياً</button>
        </div>
      </div>
    </div>

    <!-- ABOUT PAGE -->
    <div id="aboutPage">
      <div class="about-card">
        <h3>🦅 ما هو SAKR5؟</h3>
        <p>SAKR5 هو مساعد ذكاء اصطناعي متقدم مبني على تقنية Claude من Anthropic. مصمم ليكون سريعاً، دقيقاً، واحترافياً في الإجابة على جميع أسئلتك باللغة العربية والإنجليزية.</p>
      </div>
      <div class="about-card">
        <h3>⚡ المميزات</h3>
        <div class="feat-grid">
          <div class="feat">🧠 ذكاء متقدم</div>
          <div class="feat">🌐 يدعم العربية</div>
          <div class="feat">⚡ سريع الاستجابة</div>
          <div class="feat">🔒 خصوصية تامة</div>
          <div class="feat">💡 إجابات دقيقة</div>
          <div class="feat">🛠 متعدد المهام</div>
          <div class="feat">📝 كتابة احترافية</div>
          <div class="feat">💻 برمجة وتطوير</div>
        </div>
      </div>
      <div class="about-card">
        <h3>📋 تاريخ الإصدارات</h3>
        <div class="ver-list">
          <div class="ver-row"><span class="ver-tag">v1.0</span> الإصدار الأول — واجهة بسيطة</div>
          <div class="ver-row"><span class="ver-tag">v2.0</span> تصميم محسّن + شريط جانبي</div>
          <div class="ver-row"><span class="ver-tag">v3.0</span> تحسينات في الأداء</div>
          <div class="ver-row"><span class="ver-tag">v4.0</span> واجهة تفاعلية متقدمة</div>
          <div class="ver-row"><span class="ver-tag latest">v5.0 ✨</span> الإصدار الأحدث والأقوى</div>
        </div>
      </div>
      <div class="about-card">
        <h3>🔧 كيفية الاستخدام</h3>
        <p>1. احصل على مفتاح API من <strong style="color:#00e5ff">console.anthropic.com</strong><br>
        2. اضغط على زر 🔑 API في الشريط العلوي<br>
        3. أدخل مفتاحك وابدأ المحادثة فوراً!</p>
      </div>
    </div>

    <!-- INPUT -->
    <div class="input-zone" id="inputZone">
      <div class="no-key-bar" id="noKeyBar" style="display:none" onclick="openModal()">
        ⚠️ SAKR5 غير مفعّل — <u>اضغط هنا لإضافة API Key</u>
      </div>
      <div class="input-wrap">
        <textarea id="msgInput" placeholder="اسأل SAKR5 v5 أي شيء..." rows="1"
          oninput="autoResize(this)" onkeydown="handleKey(event)"></textarea>
        <button id="sendBtn" onclick="sendMsg()">
          <svg viewBox="0 0 24 24"><path d="M2 21l21-9L2 3v7l15 2-15 2v7z"/></svg>
        </button>
      </div>
      <div class="hint">SAKR5 v5.0 · مدعوم بـ Claude Sonnet · اضغط Enter للإرسال</div>
    </div>

  </div><!-- /main -->
</div><!-- /app -->

<script>
let API_KEY = '';
let busy = false;
let msgCount = 0;

const chat     = document.getElementById('chat');
const input    = document.getElementById('msgInput');
const sendBtn  = document.getElementById('sendBtn');
const noKeyBar = document.getElementById('noKeyBar');
const kDot     = document.getElementById('kDot');
const kTxt     = document.getElementById('kTxt');

// Init
window.addEventListener('load', () => {
  const saved = localStorage.getItem('sakr5v5_key');
  if (saved) { API_KEY = saved; setKeyActive(true); }
  else { noKeyBar.style.display = 'block'; }
});

function setKeyActive(on) {
  kDot.classList.toggle('on', on);
  kTxt.textContent = on ? '✓ API Key مفعّل' : 'إضافة API Key';
  noKeyBar.style.display = on ? 'none' : 'block';
}

function openModal() {
  document.getElementById('modalOverlay').classList.add('show');
  setTimeout(() => document.getElementById('keyInput').focus(), 120);
}
function closeModal() {
  document.getElementById('modalOverlay').classList.remove('show');
}
function saveKey() {
  const v = document.getElementById('keyInput').value.trim();
  if (!v.startsWith('sk-')) { alert('مفتاح غير صحيح — يجب أن يبدأ بـ sk-'); return; }
  API_KEY = v;
  localStorage.setItem('sakr5v5_key', v);
  setKeyActive(true);
  closeModal();
  addMsg('ai', '✅ تم تفعيل SAKR5 v5.0 بنجاح! أنا جاهز لمساعدتك 🦅');
}

function switchTab(t) {
  const chatEl  = document.getElementById('chat');
  const aboutEl = document.getElementById('aboutPage');
  const inputEl = document.getElementById('inputZone');
  const tChat   = document.getElementById('tabChat');
  const tAbout  = document.getElementById('tabAbout');

  if (t === 'chat') {
    chatEl.style.display  = 'flex';
    aboutEl.style.display = 'none';
    inputEl.style.display = 'block';
    tChat.classList.add('active');
    tAbout.classList.remove('active');
  } else {
    chatEl.style.display  = 'none';
    aboutEl.style.display = 'flex';
    inputEl.style.display = 'none';
    tAbout.classList.add('active');
    tChat.classList.remove('active');
  }
}

function newChat() {
  chat.innerHTML = `
    <div class="welcome" id="welcomeEl">
      <span class="eagle">🦅</span>
      <div class="w-title">SAKR5</div>
      <div class="w-ver">VERSION 5.0 · POWERED BY CLAUDE AI</div>
      <div class="w-sub">مساعدك الذكي المتقدم — سريع، دقيق، واحترافي</div>
      <div class="sugs">
        <button class="sug" onclick="useSug(this)">ما هو الذكاء الاصطناعي؟</button>
        <button class="sug" onclick="useSug(this)">ساعدني في كتابة كود Python</button>
        <button class="sug" onclick="useSug(this)">اشرح مفهوماً معقداً</button>
        <button class="sug" onclick="useSug(this)">أنشئ خطة عمل احترافية</button>
        <button class="sug" onclick="useSug(this)">ترجم نصاً إلى الإنجليزية</button>
        <button class="sug" onclick="useSug(this)">لخص موضوعاً علمياً</button>
      </div>
    </div>`;
  msgCount = 0;
  document.getElementById('currentItem').textContent = '💬 محادثة جديدة';
  switchTab('chat');
  input.focus();
}

function useSug(btn) {
  input.value = btn.textContent;
  autoResize(input);
  input.focus();
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 120) + 'px';
}

function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMsg(); }
}

function addMsg(role, text) {
  const w = document.getElementById('welcomeEl');
  if (w) w.remove();

  const row = document.createElement('div');
  row.className = `msg ${role}`;

  const av = document.createElement('div');
  av.className = 'av';
  av.textContent = role === 'ai' ? 'S5' : '👤';

  const bbl = document.createElement('div');
  bbl.className = 'bbl';
  bbl.textContent = text;

  row.appendChild(av);
  row.appendChild(bbl);
  chat.appendChild(row);
  chat.scrollTop = chat.scrollHeight;

  if (msgCount === 0 && role === 'user') {
    const short = text.slice(0, 22) + (text.length > 22 ? '…' : '');
    document.getElementById('currentItem').textContent = '💬 ' + short;
  }
  if (role === 'user') msgCount++;
  return bbl;
}

function addTyping() {
  const w = document.getElementById('welcomeEl');
  if (w) w.remove();
  const row = document.createElement('div');
  row.className = 'msg ai'; row.id = 'typingRow';
  const av = document.createElement('div'); av.className = 'av'; av.textContent = 'S5';
  const bbl = document.createElement('div'); bbl.className = 'bbl';
  bbl.innerHTML = '<div class="dots"><span></span><span></span><span></span></div>';
  row.appendChild(av); row.appendChild(bbl);
  chat.appendChild(row);
  chat.scrollTop = chat.scrollHeight;
}
function removeTyping() {
  const t = document.getElementById('typingRow');
  if (t) t.remove();
}

async function sendMsg() {
  if (busy) return;
  const text = input.value.trim();
  if (!text) return;
  if (!API_KEY) { openModal(); return; }

  addMsg('user', text);
  input.value = ''; input.style.height = 'auto';
  busy = true; sendBtn.disabled = true;
  addTyping();

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': API_KEY,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: 'أنت SAKR5 نسخة 5.0، مساعد ذكاء اصطناعي متقدم وقوي. أجب دائماً باللغة العربية بأسلوب واضح واحترافي وذكي. اسمك SAKR5 وليس Claude. كن دقيقاً وسريعاً ومفيداً.',
        messages: [{ role: 'user', content: text }]
      })
    });

    const data = await res.json();
    removeTyping();

    if (data.content?.[0]?.text) {
      addMsg('ai', data.content[0].text);
    } else {
      addMsg('ai', '❌ خطأ: ' + (data.error?.message || 'غير معروف'));
    }
  } catch (err) {
    removeTyping();
    addMsg('ai', '❌ فشل الاتصال. تحقق من API Key والإنترنت.');
  }

  busy = false;
  sendBtn.disabled = false;
  input.focus();
}
</script>
</body>
</html>
