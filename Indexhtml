<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>SAKR5 V5</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #010912;
  --bg2: #071220;
  --bg3: #0c1e35;
  --blue: #1a6dff;
  --accent: #00e5ff;
  --green: #00ff99;
  --white: #f0f8ff;
  --dim: #6a9cc8;
  --border: rgba(26,109,255,0.18);
}
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html, body { height:100%; overflow:hidden; }
body {
  font-family:'Tajawal',sans-serif;
  background:var(--bg);
  color:var(--white);
  display:flex;
  flex-direction:column;
  height:100dvh;
}

/* BG */
body::before {
  content:'';
  position:fixed; inset:0; pointer-events:none; z-index:0;
  background:
    radial-gradient(ellipse 60% 40% at 20% 10%, rgba(26,109,255,0.1) 0%, transparent 60%),
    radial-gradient(ellipse 40% 30% at 80% 80%, rgba(0,229,255,0.06) 0%, transparent 50%);
}
body::after {
  content:'';
  position:fixed; inset:0; pointer-events:none; z-index:0;
  background-image:
    linear-gradient(rgba(26,109,255,0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(26,109,255,0.02) 1px, transparent 1px);
  background-size:48px 48px;
}

/* HEADER */
.header {
  position:relative; z-index:10;
  display:flex; align-items:center; justify-content:space-between;
  padding:12px 16px;
  background:rgba(1,9,18,0.95);
  border-bottom:1px solid var(--border);
  backdrop-filter:blur(20px);
  flex-shrink:0;
}
.logo-row { display:flex; align-items:center; gap:10px; }
.logo-icon {
  width:36px; height:36px; border-radius:9px;
  background:linear-gradient(135deg,#0d2a5e,var(--blue));
  display:flex; align-items:center; justify-content:center;
  font-family:'Space Mono',monospace; font-size:10px; font-weight:700;
  color:var(--accent); box-shadow:0 0 14px rgba(0,229,255,0.25);
  flex-shrink:0;
}
.logo-name {
  font-family:'Space Mono',monospace;
  font-size:18px; font-weight:700; letter-spacing:3px;
  background:linear-gradient(135deg,#fff,var(--accent));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  background-clip:text;
}
.logo-ver { font-family:'Space Mono',monospace; font-size:8px; color:var(--dim); letter-spacing:1px; }

.header-right { display:flex; align-items:center; gap:8px; }
.status-pill {
  display:flex; align-items:center; gap:5px;
  padding:4px 10px; border-radius:20px;
  border:1px solid var(--border); font-size:11px; color:var(--dim);
  font-family:'Space Mono',monospace;
}
.s-dot { width:6px; height:6px; border-radius:50%; background:#ff4466; transition:all .3s; }
.s-dot.on { background:var(--green); box-shadow:0 0 6px var(--green); }
.api-btn {
  padding:5px 10px;
  background:transparent; border:1px solid var(--border); border-radius:8px;
  color:var(--dim); font-size:11px; font-family:'Space Mono',monospace; cursor:pointer;
  transition:all .2s;
}
.api-btn:hover { border-color:var(--accent); color:var(--accent); }

/* TABS */
.tabs {
  display:flex; flex-shrink:0;
  border-bottom:1px solid rgba(26,109,255,0.12);
  background:rgba(1,9,18,0.8);
  position:relative; z-index:5;
}
.tab {
  flex:1; padding:10px;
  background:transparent; border:none;
  border-bottom:2px solid transparent;
  color:var(--dim); font-family:'Tajawal',sans-serif;
  font-size:13px; cursor:pointer; transition:all .2s; text-align:center;
}
.tab.active { border-bottom-color:var(--blue); color:var(--white); }

/* CHAT */
#chatArea {
  flex:1; overflow-y:auto;
  padding:16px;
  display:flex; flex-direction:column; gap:16px;
  scroll-behavior:smooth;
  position:relative; z-index:5;
}
#chatArea::-webkit-scrollbar { width:2px; }
#chatArea::-webkit-scrollbar-thumb { background:rgba(26,109,255,0.2); border-radius:2px; }

/* Welcome */
.welcome { text-align:center; padding:32px 16px; animation:fadeUp .6s ease; }
.eagle { font-size:56px; display:block; margin-bottom:16px; animation:float 3s ease-in-out infinite; filter:drop-shadow(0 0 20px rgba(0,229,255,0.45)); }
@keyframes float { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-10px);} }
.w-title { font-family:'Space Mono',monospace; font-size:28px; letter-spacing:5px; background:linear-gradient(135deg,#fff,var(--accent),var(--green)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; margin-bottom:4px; }
.w-ver { font-family:'Space Mono',monospace; font-size:9px; color:var(--dim); letter-spacing:2px; margin-bottom:10px; }
.w-sub { color:var(--dim); font-size:13px; line-height:1.7; margin-bottom:20px; }
.sugs { display:flex; flex-wrap:wrap; gap:8px; justify-content:center; }
.sug {
  padding:8px 14px;
  background:rgba(26,109,255,0.07); border:1px solid var(--border); border-radius:20px;
  color:var(--dim); font-size:12px; cursor:pointer; transition:all .2s;
  font-family:'Tajawal',sans-serif;
}
.sug:active { background:rgba(26,109,255,0.2); color:var(--white); }

/* Messages */
.msg { display:flex; gap:8px; animation:fadeUp .3s ease; }
@keyframes fadeUp { from{opacity:0;transform:translateY(12px);} to{opacity:1;transform:translateY(0);} }
.msg.user { flex-direction:row-reverse; max-width:85%; margin-left:auto; }
.msg.ai { max-width:90%; margin-right:auto; }
.av {
  width:32px; height:32px; border-radius:8px;
  display:flex; align-items:center; justify-content:center;
  flex-shrink:0; align-self:flex-end;
}
.msg.ai .av { background:linear-gradient(135deg,#091e3a,var(--blue)); font-family:'Space Mono',monospace; font-size:8px; font-weight:700; color:var(--accent); box-shadow:0 0 10px rgba(26,109,255,0.35); }
.msg.user .av { background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1); font-size:14px; }
.bbl { padding:11px 14px; border-radius:12px; font-size:14px; line-height:1.75; word-break:break-word; white-space:pre-wrap; }
.msg.ai .bbl { background:rgba(7,18,32,0.95); border:1px solid var(--border); border-bottom-right-radius:3px; color:#cce4ff; }
.msg.user .bbl { background:linear-gradient(135deg,var(--blue),#0a44cc); border-bottom-left-radius:3px; color:#fff; box-shadow:0 3px 12px rgba(26,109,255,0.25); }

/* Typing */
.dots { display:flex; gap:4px; align-items:center; padding:3px 0; }
.dots span { width:6px; height:6px; border-radius:50%; background:var(--accent); display:block; }
.dots span:nth-child(1){animation:bounce 1.2s infinite;}
.dots span:nth-child(2){animation:bounce 1.2s .2s infinite;}
.dots span:nth-child(3){animation:bounce 1.2s .4s infinite;}
@keyframes bounce{0%,60%,100%{transform:translateY(0);opacity:.3;}30%{transform:translateY(-7px);opacity:1;}}

/* INPUT */
.input-zone {
  flex-shrink:0; padding:12px 14px 16px;
  background:rgba(1,9,18,0.95); border-top:1px solid var(--border);
  backdrop-filter:blur(20px); position:relative; z-index:10;
}
.no-key-bar {
  text-align:center; margin-bottom:8px; padding:8px 12px;
  background:rgba(255,100,50,0.07); border:1px solid rgba(255,100,50,0.2);
  border-radius:9px; font-size:12px; color:#ff9977; cursor:pointer;
}
.input-wrap {
  display:flex; align-items:flex-end; gap:8px;
  background:rgba(255,255,255,0.04); border:1px solid var(--border);
  border-radius:12px; padding:9px 12px; transition:border-color .2s;
}
.input-wrap:focus-within { border-color:rgba(26,109,255,0.5); }
#msgInput {
  flex:1; background:transparent; border:none; outline:none;
  color:var(--white); font-family:'Tajawal',sans-serif;
  font-size:14px; resize:none; line-height:1.6; max-height:100px; min-height:24px;
}
#msgInput::placeholder { color:rgba(106,156,200,0.4); }
#sendBtn {
  width:38px; height:38px; border-radius:9px;
  background:linear-gradient(135deg,var(--blue),#0a44cc);
  border:none; cursor:pointer; flex-shrink:0;
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 0 14px rgba(26,109,255,0.3); transition:all .2s;
}
#sendBtn:active { transform:scale(0.95); }
#sendBtn:disabled { opacity:.35; cursor:default; }
#sendBtn svg { width:16px; height:16px; fill:#fff; }
.hint { text-align:center; margin-top:6px; font-size:10px; color:rgba(106,156,200,0.25); font-family:'Space Mono',monospace; }

/* ABOUT */
#aboutPage {
  flex:1; overflow-y:auto; padding:16px;
  display:none; flex-direction:column; gap:12px;
  position:relative; z-index:5;
}
.about-card { background:rgba(7,18,32,0.9); border:1px solid var(--border); border-radius:12px; padding:18px; }
.about-card h3 { font-family:'Space Mono',monospace; font-size:11px; letter-spacing:2px; color:var(--accent); margin-bottom:10px; }
.about-card p { font-size:13px; color:#8ab0d8; line-height:1.8; }
.feat-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:8px; }
.feat { background:rgba(26,109,255,0.07); border:1px solid rgba(26,109,255,0.14); border-radius:8px; padding:9px 12px; font-size:12px; color:#cce4ff; }
.ver-list { display:flex; flex-direction:column; gap:7px; margin-top:6px; }
.ver-row { display:flex; align-items:center; gap:8px; font-size:13px; color:#8ab0d8; }
.ver-tag { padding:2px 8px; border-radius:20px; background:rgba(26,109,255,0.12); font-family:'Space Mono',monospace; font-size:9px; color:#3d8bff; }
.ver-tag.latest { background:rgba(0,229,255,0.12); color:var(--accent); }

/* NEW CHAT BTN */
.new-chat-bar {
  padding:8px 14px 0; position:relative; z-index:5;
  display:none;
}
.new-chat-bar button {
  width:100%; padding:10px;
  background:linear-gradient(135deg,var(--blue),#0a44cc);
  border:none; border-radius:10px; color:#fff;
  font-family:'Tajawal',sans-serif; font-size:14px; font-weight:700;
  cursor:pointer; box-shadow:0 3px 12px rgba(26,109,255,0.3);
}

/* MODAL */
#modalOverlay {
  display:none; position:fixed; inset:0;
  background:rgba(1,9,18,0.9); backdrop-filter:blur(12px);
  z-index:200; align-items:flex-end; justify-content:center;
}
#modalOverlay.show { display:flex; }
.modal {
  background:var(--bg3); border:1px solid var(--border);
  border-radius:18px 18px 0 0; padding:24px 20px 32px;
  width:100%; max-width:500px;
  box-shadow:0 -20px 50px rgba(0,0,0,0.6);
  animation:slideUp .3s ease;
}
@keyframes slideUp { from{transform:translateY(100%);} to{transform:translateY(0);} }
.m-handle { width:40px; height:4px; border-radius:2px; background:rgba(255,255,255,0.15); margin:0 auto 20px; }
.m-title { font-family:'Space Mono',monospace; font-size:14px; letter-spacing:2px; color:var(--accent); margin-bottom:8px; }
.m-desc { font-size:13px; color:var(--dim); line-height:1.7; margin-bottom:16px; }
.m-desc strong { color:var(--accent); }
#keyInput {
  width:100%; padding:12px 14px;
  background:rgba(255,255,255,0.05); border:1px solid var(--border); border-radius:10px;
  color:var(--white); font-size:13px; font-family:'Space Mono',monospace;
  outline:none; margin-bottom:12px; direction:ltr; transition:border-color .2s;
}
#keyInput:focus { border-color:var(--blue); }
.m-btns { display:flex; gap:10px; }
.m-save {
  flex:1; padding:13px;
  background:linear-gradient(135deg,var(--blue),#0a44cc);
  border:none; border-radius:10px; color:#fff;
  font-family:'Tajawal',sans-serif; font-size:15px; font-weight:700; cursor:pointer;
}
.m-cancel {
  padding:13px 16px; background:transparent;
  border:1px solid var(--border); border-radius:10px; color:var(--dim);
  font-family:'Tajawal',sans-serif; font-size:14px; cursor:pointer;
}

@keyframes blink { 0%,100%{opacity:1;} 50%{opacity:.3;} }
</style>
</head>
<body>

<!-- MODAL -->
<div id="modalOverlay">
  <div class="modal">
    <div class="m-handle"></div>
    <div class="m-title">🔑 SAKR5 V5 · API KEY</div>
    <div class="m-desc">أدخل مفتاح Claude API لتفعيل SAKR5.<br>احصل عليه من <strong>console.anthropic.com</strong></div>
    <input type="password" id="keyInput" placeholder="sk-ant-api03-..." />
    <div class="m-btns">
      <button class="m-save" onclick="saveKey()">تفعيل SAKR5 🦅</button>
      <button class="m-cancel" onclick="closeModal()">إلغاء</button>
    </div>
  </div>
</div>

<!-- HEADER -->
<div class="header">
  <div class="logo-row">
    <div class="logo-icon">S5</div>
    <div>
      <div class="logo-name">SAKR5</div>
      <div class="logo-ver">VERSION 5.0 · AI ASSISTANT</div>
    </div>
  </div>
  <div class="header-right">
    <div class="status-pill">
      <div class="s-dot" id="sDot"></div>
      <span id="sTxt">غير مفعّل</span>
    </div>
    <button class="api-btn" onclick="openModal()">🔑</button>
  </div>
</div>

<!-- TABS -->
<div class="tabs">
  <button class="tab active" id="tabChat" onclick="switchTab('chat')">💬 المحادثة</button>
  <button class="tab" id="tabAbout" onclick="switchTab('about')">🦅 عن SAKR5</button>
</div>

<!-- NEW CHAT BAR (shown in chat tab) -->
<div class="new-chat-bar" id="newChatBar">
  <button onclick="newChat()">+ محادثة جديدة</button>
</div>

<!-- CHAT -->
<div id="chatArea">
  <div class="welcome" id="welcomeEl">
    <span class="eagle">🦅</span>
    <div class="w-title">SAKR5</div>
    <div class="w-ver">VERSION 5.0 · POWERED BY CLAUDE AI</div>
    <div class="w-sub">مساعدك الذكي المتقدم<br>سريع · دقيق · احترافي</div>
    <div class="sugs">
      <button class="sug" onclick="useSug(this)">ما هو الذكاء الاصطناعي؟</button>
      <button class="sug" onclick="useSug(this)">ساعدني في كتابة كود</button>
      <button class="sug" onclick="useSug(this)">اشرح مفهوماً معقداً</button>
      <button class="sug" onclick="useSug(this)">أنشئ خطة عمل</button>
      <button class="sug" onclick="useSug(this)">ترجم نصاً</button>
      <button class="sug" onclick="useSug(this)">لخص موضوعاً</button>
    </div>
  </div>
</div>

<!-- ABOUT -->
<div id="aboutPage">
  <div class="about-card">
    <h3>🦅 ما هو SAKR5؟</h3>
    <p>مساعد ذكاء اصطناعي متقدم مبني على Claude من Anthropic. سريع، دقيق، ويدعم العربية بالكامل.</p>
  </div>
  <div class="about-card">
    <h3>⚡ المميزات</h3>
    <div class="feat-grid">
      <div class="feat">🧠 ذكاء متقدم</div>
      <div class="feat">🌐 يدعم العربية</div>
      <div class="feat">⚡ سريع الاستجابة</div>
      <div class="feat">🔒 خصوصية تامة</div>
      <div class="feat">💡 إجابات دقيقة</div>
      <div class="feat">🛠 متعدد المهام</div>
    </div>
  </div>
  <div class="about-card">
    <h3>📋 الإصدارات</h3>
    <div class="ver-list">
      <div class="ver-row"><span class="ver-tag">v1.0</span> الإصدار الأول</div>
      <div class="ver-row"><span class="ver-tag">v2.0</span> شريط جانبي + تصميم محسّن</div>
      <div class="ver-row"><span class="ver-tag latest">v5.0 ✨</span> الأحدث والأقوى</div>
    </div>
  </div>
  <div class="about-card">
    <h3>🔧 كيفية الاستخدام</h3>
    <p>1. احصل على API Key من <strong style="color:#00e5ff">console.anthropic.com</strong><br>2. اضغط 🔑 في الأعلى<br>3. أدخل المفتاح وابدأ! 🚀</p>
  </div>
</div>

<!-- INPUT -->
<div class="input-zone" id="inputZone">
  <div class="no-key-bar" id="noKeyBar" onclick="openModal()">
    ⚠️ غير مفعّل — <u>اضغط لإضافة API Key</u>
  </div>
  <div class="input-wrap">
    <textarea id="msgInput" placeholder="اسأل SAKR5 أي شيء..." rows="1"
      oninput="autoResize(this)" onkeydown="handleKey(event)"></textarea>
    <button id="sendBtn" onclick="sendMsg()">
      <svg viewBox="0 0 24 24"><path d="M2 21l21-9L2 3v7l15 2-15 2v7z"/></svg>
    </button>
  </div>
  <div class="hint">SAKR5 v5.0 · Claude Sonnet · Enter للإرسال</div>
</div>

<script>
let API_KEY = '';
let busy = false;

const chatArea = document.getElementById('chatArea');
const input    = document.getElementById('msgInput');
const sendBtn  = document.getElementById('sendBtn');
const noKeyBar = document.getElementById('noKeyBar');
const sDot     = document.getElementById('sDot');
const sTxt     = document.getElementById('sTxt');

window.addEventListener('load', () => {
  const k = localStorage.getItem('sakr5v5_key');
  if (k) { API_KEY = k; setActive(true); }
});

function setActive(on) {
  sDot.classList.toggle('on', on);
  sTxt.textContent = on ? 'مفعّل ✓' : 'غير مفعّل';
  noKeyBar.style.display = on ? 'none' : 'block';
}

function openModal() {
  document.getElementById('modalOverlay').classList.add('show');
  setTimeout(() => document.getElementById('keyInput').focus(), 200);
}
function closeModal() {
  document.getElementById('modalOverlay').classList.remove('show');
}
function saveKey() {
  const v = document.getElementById('keyInput').value.trim();
  if (!v.startsWith('sk-')) { alert('مفتاح غير صحيح — يجب أن يبدأ بـ sk-'); return; }
  API_KEY = v;
  localStorage.setItem('sakr5v5_key', v);
  setActive(true);
  closeModal();
  addMsg('ai', '✅ تم تفعيل SAKR5 v5.0! كيف يمكنني مساعدتك؟ 🦅');
}

function switchTab(t) {
  const ca = document.getElementById('chatArea');
  const ap = document.getElementById('aboutPage');
  const iz = document.getElementById('inputZone');
  const nb = document.getElementById('newChatBar');
  const tc = document.getElementById('tabChat');
  const ta = document.getElementById('tabAbout');

  if (t === 'chat') {
    ca.style.display = 'flex';
    ap.style.display = 'none';
    iz.style.display = 'block';
    nb.style.display = 'block';
    tc.classList.add('active');
    ta.classList.remove('active');
  } else {
    ca.style.display = 'none';
    ap.style.display = 'flex';
    iz.style.display = 'none';
    nb.style.display = 'none';
    ta.classList.add('active');
    tc.classList.remove('active');
  }
}

function newChat() {
  chatArea.innerHTML = `
    <div class="welcome" id="welcomeEl">
      <span class="eagle">🦅</span>
      <div class="w-title">SAKR5</div>
      <div class="w-ver">VERSION 5.0 · POWERED BY CLAUDE AI</div>
      <div class="w-sub">مساعدك الذكي المتقدم<br>سريع · دقيق · احترافي</div>
      <div class="sugs">
        <button class="sug" onclick="useSug(this)">ما هو الذكاء الاصطناعي؟</button>
        <button class="sug" onclick="useSug(this)">ساعدني في كتابة كود</button>
        <button class="sug" onclick="useSug(this)">اشرح مفهوماً معقداً</button>
        <button class="sug" onclick="useSug(this)">أنشئ خطة عمل</button>
        <button class="sug" onclick="useSug(this)">ترجم نصاً</button>
        <button class="sug" onclick="useSug(this)">لخص موضوعاً</button>
      </div>
    </div>`;
  input.focus();
}

function useSug(btn) {
  input.value = btn.textContent;
  autoResize(input);
  input.focus();
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 100) + 'px';
}

function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMsg(); }
}

function addMsg(role, text) {
  const w = document.getElementById('welcomeEl');
  if (w) w.remove();

  const row = document.createElement('div');
  row.className = `msg ${role}`;
  const av = document.createElement('div'); av.className = 'av';
  av.textContent = role === 'ai' ? 'S5' : '👤';
  const bbl = document.createElement('div'); bbl.className = 'bbl';
  bbl.textContent = text;
  row.appendChild(av); row.appendChild(bbl);
  chatArea.appendChild(row);
  chatArea.scrollTop = chatArea.scrollHeight;
}

function addTyping() {
  const w = document.getElementById('welcomeEl');
  if (w) w.remove();
  const row = document.createElement('div'); row.className = 'msg ai'; row.id = 'typingRow';
  const av = document.createElement('div'); av.className = 'av'; av.textContent = 'S5';
  const bbl = document.createElement('div'); bbl.className = 'bbl';
  bbl.innerHTML = '<div class="dots"><span></span><span></span><span></span></div>';
  row.appendChild(av); row.appendChild(bbl);
  chatArea.appendChild(row);
  chatArea.scrollTop = chatArea.scrollHeight;
}
function removeTyping() {
  const t = document.getElementById('typingRow');
  if (t) t.remove();
}

async function sendMsg() {
  if (busy) return;
  const text = input.value.trim();
  if (!text) return;
  if (!API_KEY) { openModal(); return; }

  addMsg('user', text);
  input.value = ''; input.style.height = 'auto';
  busy = true; sendBtn.disabled = true;
  addTyping();

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST',
      headers:{
        'Content-Type':'application/json',
        'x-api-key': API_KEY,
        'anthropic-version':'2023-06-01',
        'anthropic-dangerous-direct-browser-access':'true'
      },
      body: JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1000,
        system:'أنت SAKR5 نسخة 5.0، مساعد ذكاء اصطناعي متقدم. أجب دائماً باللغة العربية بأسلوب واضح واحترافي. اسمك SAKR5 وليس Claude.',
        messages:[{ role:'user', content:text }]
      })
    });
    const data = await res.json();
    removeTyping();
    if (data.content?.[0]?.text) {
      addMsg('ai', data.content[0].text);
    } else {
      addMsg('ai', '❌ خطأ: ' + (data.error?.message || 'غير معروف'));
    }
  } catch {
    removeTyping();
    addMsg('ai', '❌ فشل الاتصال. تحقق من API Key والإنترنت.');
  }
  busy = false; sendBtn.disabled = false;
}

// Init
switchTab('chat');
</script>
